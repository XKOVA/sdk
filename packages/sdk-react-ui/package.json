{
  "name": "@xkova/sdk-react-ui",
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "description": "Optional shadcn/Tailwind starter components for the XKOVA SDK.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XKOVA/sdk.git",
    "directory": "packages/sdk-react-ui"
  },
  "homepage": "https://github.com/XKOVA/sdk",
  "bugs": {
    "url": "https://github.com/XKOVA/sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "./styles.css"
  ],
  "files": [
    "dist",
    "styles.css",
    "README.md"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @xkova/sdk-react build",
    "build": "pnpm run build:styles && pnpm run build:types",
    "build:styles": "pnpm run build:styles:raw && node ./scripts/scope-styles.mjs ./styles.raw.css ./styles.css && rm -f ./styles.raw.css",
    "build:styles:raw": "tailwindcss --config ./tailwind.config.mjs -i ./src/styles.source.css -o ./styles.raw.css --minify",
    "build:types": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "pnpm build && node --test tests/*.test.js"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "tailwind-merge": "^3.4.0",
    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "@xkova/sdk-core": "^0.1.0",
    "@xkova/sdk-react": "^0.1.0",
    "react-dom": ">=16.8.0",
    "react": ">=16.8.0",
    "sonner": "^1.5.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.17.0",
    "@xkova/sdk-core": "workspace:^",
    "@xkova/sdk-react": "workspace:^",
    "postcss": "^8.5.6",
    "postcss-prefix-selector": "^2.1.1",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@radix-ui/react-tooltip": "^1.1.8",
    "sonner": "^1.5.1",
    "typescript": "^5.7.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./styles.css",
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js"
    }
  }
}
