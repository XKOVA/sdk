{
  "name": "@xkova/sdk-react",
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "description": "React provider, hooks, and UI primitives for the XKOVA SDK.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XKOVA/sdk.git",
    "directory": "packages/sdk-react"
  },
  "homepage": "https://github.com/XKOVA/sdk",
  "bugs": {
    "url": "https://github.com/XKOVA/sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @xkova/sdk-core build",
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "pnpm build && node --test tests/*.test.js"
  },
  "dependencies": {
    "@xkova/sdk-browser": "workspace:^",
    "@xkova/sdk-core": "workspace:^",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.1.0",
    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "react-dom": ">=16.8.0",
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/uuid": "^10.0.0",
    "@xkova/sdk-core": "workspace:^",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
