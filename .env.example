# Required: OAuth server base URL (protocol host, not tenant auth domain)
XKOVA_BASE_URL=https://auth.xkova.com

# Required: Apps API base URL
XKOVA_API_URL=https://api.xkova.com/api/v1

# Required: OAuth client credentials (from tenant console)
XKOVA_CLIENT_ID=
XKOVA_CLIENT_SECRET=

# Required: OAuth redirect URI (must match client config)
XKOVA_REDIRECT_URI=http://localhost:3000/callback

# For Next.js / browser apps, use NEXT_PUBLIC_ prefix:
# NEXT_PUBLIC_XKOVA_BASE_URL=https://auth.xkova.com
# NEXT_PUBLIC_XKOVA_API_URL=https://api.xkova.com/api/v1
