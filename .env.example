# Required: Core runtime base URL (single host for /auth/* and /api/v1/*)
XKOVA_CORE_URL=https://core.xkova.com

# Optional: environment shorthand (local/dev/staging/production)
# XKOVA_ENV=local

# Required: OAuth client credentials (from tenant console)
XKOVA_CLIENT_ID=
XKOVA_CLIENT_SECRET=

# Required: OAuth redirect URI (must match client config)
XKOVA_REDIRECT_URI=http://localhost:3000/callback

# For Next.js / browser apps, use NEXT_PUBLIC_ prefix:
# NEXT_PUBLIC_XKOVA_CORE_URL=https://core.xkova.com
# NEXT_PUBLIC_XKOVA_ENV=local
